@startuml Контекстная диаграмма "Торгуй сам" (IDEF0 — A-0)
skinparam BackgroundColor transparent
skinparam defaultFontName Arial
skinparam defaultFontSize 11
skinparam RectangleBorderColor #000000
skinparam RectangleBorderThickness 2
skinparam ArrowColor #000000
skinparam ArrowThickness 1.5
skinparam roundcorner 0
skinparam padding 4
hide stereotype

' Центральный блок
rectangle "Веб-маркетплейс\nобъявлений\n«Торгуй сам»" as system #white

' ВХОДЫ (слева)
[Данные товаров и услуг] -right-> system
[Сообщения в онлайн-чат] -right-> system
[Данные регистрации и профиля клиента] -right-> system
[Запросы каталога, поиска и фильтров] -right-> system
[Данные пополнения баланса] -right-> system
[Логин и пароль] -right-> system

' ВЫХОДЫ (справа)
system -right-> [Отфильтрованный каталог]
system -right-> [Карточки товаров]
system -right-> [Статистика просмотров и покупок]
system -right-> [Учетная запись]
system -right-> [Уведомления о новых сообщениях]
system -right-> [Сохраненный диалог в чате]

' УПРАВЛЕНИЕ (сверху)
[Устав] -down-> system
[Нормативные\nакты] -down-> system

' МЕХАНИЗМЫ (снизу)
[Гость] -up-> system
[Клиент] -up-> system
[Администратор] -up-> system

@enduml
